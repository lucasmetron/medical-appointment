{
  "name": "prompt-chaining-article-generator",
  "version": "1.0.0",
  "description": "Technical article generator using LangChain prompt chaining with reusable templates",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "start": "node --env-file .env src/index.ts",
    "dev": "node --watch --inspect --env-file .env src/index.ts",
    "test": "node --env-file .env --test tests/**/*.test.ts",
    "test:dev": "node --inspect --env-file .env --test --watch tests/**/*.test.ts",
    "test:unit:dev": "node --inspect --test --watch tests/**/*unit.test.ts",
    "test:unit": "node --inspect --test tests/**/*unit.test.ts",
    "test:e2e:dev": "node --inspect --env-file .env --test --watch tests/**/*e2e.test.ts",
    "test:e2e": "node --inspect --env-file .env --test tests/**/*e2e.test.ts",
    "langgraph:serve": "langgraphjs dev"
  },
  "keywords": [
    "langchain",
    "prompt-chaining",
    "article-generator",
    "openrouter",
    "ollama"
  ],
  "author": "erickwendel",
  "license": "MIT",
  "dependencies": {
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.2",
    "@langchain/openai": "^1.2.5",
    "@openrouter/sdk": "^0.5.1",
    "fastify": "^5.7.4",
    "langchain": "^1.4.2",
    "zod": "^3.25.76",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@langchain/langgraph-cli": "^1.2.2",
    "@types/node": "^24.10.12"
  },
  "engines": {
    "node": ">=24.10.0"
  }
}
